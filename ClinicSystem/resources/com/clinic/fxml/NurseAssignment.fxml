<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.clinic.controller.NurseAssignmentController"
      spacing="0"
      style="-fx-background-color: #F8FAFC;">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-padding: 0 0 20 0;">
        <VBox>
            <Label text="Nurse Assignment"
                   style="-fx-font-size: 20px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #0F172A;"/>
            <Label text="Assign nurses to patients and appointments"
                   style="-fx-font-size: 12px;
                          -fx-text-fill: #64748B;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="➕  New Assignment"
                onAction="#clearForm"
                style="-fx-background-color: #059669;
                       -fx-text-fill: white;
                       -fx-padding: 10 20;
                       -fx-background-radius: 8;
                       -fx-cursor: hand;
                       -fx-font-weight: bold;"/>
    </HBox>

    <!-- FILTER BAR -->
    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-padding: 0 0 16 0;">
        <ComboBox fx:id="filterStatus"
                  promptText="All Status"
                  style="-fx-background-radius: 8;"/>
        <ComboBox fx:id="filterNurse"
                  promptText="All Nurses"
                  prefWidth="180"
                  style="-fx-background-radius: 8;"/>
        <Button text="🔄 Reset"
                onAction="#resetFilter"
                style="-fx-background-color: #F1F5F9;
                       -fx-text-fill: #475569;
                       -fx-padding: 10 16;
                       -fx-background-radius: 8;
                       -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="countLabel"
               style="-fx-font-size: 12px;
                      -fx-text-fill: #64748B;"/>
    </HBox>

    <!-- CONTENT -->
    <HBox spacing="16" VBox.vgrow="ALWAYS">

        <!-- TABLE -->
        <TableView fx:id="assignmentTable"
                   HBox.hgrow="ALWAYS"
                   VBox.vgrow="ALWAYS"
                   style="-fx-background-color: white;
                          -fx-background-radius: 12;
                          -fx-effect: dropshadow(gaussian,
                            rgba(0,0,0,0.06),12,0,0,4);">
            <columns>
                <TableColumn fx:id="colId"
                             text="ID"
                             prefWidth="50"/>
                <TableColumn fx:id="colNurse"
                             text="Assigned Nurse"
                             prefWidth="160"/>
                <TableColumn fx:id="colPatient"
                             text="Patient"
                             prefWidth="160"/>
                <TableColumn fx:id="colType"
                             text="Type"
                             prefWidth="100"/>
                <TableColumn fx:id="colPriority"
                             text="Priority"
                             prefWidth="90"/>
                <TableColumn fx:id="colTask"
                             text="Task"
                             prefWidth="180"/>
                <TableColumn fx:id="colStatus"
                             text="Status"
                             prefWidth="110"/>
                <TableColumn fx:id="colDate"
                             text="Assigned"
                             prefWidth="120"/>
            </columns>
            <placeholder>
                <Label text="No assignments yet. Click 'New Assignment' to start."
                       style="-fx-text-fill: #94A3B8;"/>
            </placeholder>
        </TableView>

        <!-- FORM -->
        <VBox prefWidth="320" minWidth="320"
              spacing="0"
              style="-fx-background-color: white;
                     -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian,
                       rgba(0,0,0,0.06),12,0,0,4);">

            <!-- Form Header -->
            <VBox style="-fx-padding: 16 20;
                         -fx-background-color: #059669;
                         -fx-background-radius: 12 12 0 0;">
                <Label fx:id="formTitle"
                       text="New Assignment"
                       style="-fx-font-size: 15px;
                              -fx-font-weight: bold;
                              -fx-text-fill: white;"/>
                <Label text="Assign a nurse to a patient"
                       style="-fx-font-size: 11px;
                              -fx-text-fill: #D1FAE5;"/>
            </VBox>

            <ScrollPane fitToWidth="true"
                        VBox.vgrow="ALWAYS"
                        style="-fx-background: transparent;
                               -fx-background-color: transparent;">
                <VBox spacing="12"
                      style="-fx-padding: 16;">

                    <!-- Select Nurse -->
                    <Label text="ASSIGN TO NURSE *"
                           style="-fx-font-size: 11px;
                                  -fx-text-fill: #64748B;
                                  -fx-font-weight: bold;"/>
                    <ComboBox fx:id="nurseCombo"
                              maxWidth="Infinity"
                              promptText="Select nurse..."/>

                    <!-- Select Patient -->
                    <Label text="PATIENT *"
                           style="-fx-font-size: 11px;
                                  -fx-text-fill: #64748B;
                                  -fx-font-weight: bold;"/>
                    <ComboBox fx:id="patientCombo"
                              maxWidth="Infinity"
                              promptText="Select patient..."/>

                    <!-- Assignment Type -->
                    <Label text="ASSIGNMENT TYPE"
                           style="-fx-font-size: 11px;
                                  -fx-text-fill: #64748B;
                                  -fx-font-weight: bold;"/>
                    <ComboBox fx:id="typeCombo"
                              maxWidth="Infinity"/>

                    <!-- Link to Appointment -->
                    <Label text="LINK TO APPOINTMENT (Optional)"
                           style="-fx-font-size: 11px;
                                  -fx-text-fill: #64748B;
                                  -fx-font-weight: bold;"/>
                    <ComboBox fx:id="appointmentCombo"
                              maxWidth="Infinity"
                              promptText="Select appointment (optional)..."/>

                    <!-- Priority -->
                    <Label text="PRIORITY"
                           style="-fx-font-size: 11px;
                                  -fx-text-fill: #64748B;
                                  -fx-font-weight: bold;"/>
                    <ComboBox fx:id="priorityCombo"
                              maxWidth="Infinity"/>

                    <!-- Task Description -->
                    <Label text="TASK DESCRIPTION *"
                           style="-fx-font-size: 11px;
                                  -fx-text-fill: #64748B;
                                  -fx-font-weight: bold;"/>
                    <TextArea fx:id="taskArea"
                              prefRowCount="3"
                              promptText="Describe the task or instructions for the nurse..."
                              style="-fx-border-color: #E2E8F0;
                                     -fx-border-radius: 8;
                                     -fx-font-size: 13px;"/>

                    <!-- Notes -->
                    <Label text="ADDITIONAL NOTES"
                           style="-fx-font-size: 11px;
                                  -fx-text-fill: #64748B;
                                  -fx-font-weight: bold;"/>
                    <TextArea fx:id="notesArea"
                              prefRowCount="2"
                              promptText="Any extra notes..."
                              style="-fx-border-color: #E2E8F0;
                                     -fx-border-radius: 8;
                                     -fx-font-size: 13px;"/>

                    <!-- Status Label -->
                    <Label fx:id="statusLabel"
                           text="" wrapText="true"
                           style="-fx-font-size: 12px;"/>

                    <!-- Save Button -->
                    <Button fx:id="saveButton"
                            text="📋  Assign Nurse"
                            maxWidth="Infinity"
                            onAction="#handleSave"
                            style="-fx-background-color: #059669;
                                   -fx-text-fill: white;
                                   -fx-font-size: 13px;
                                   -fx-padding: 12;
                                   -fx-background-radius: 8;
                                   -fx-cursor: hand;
                                   -fx-font-weight: bold;"/>

                    <!-- Cancel + Clear -->
                    <HBox spacing="8">
                        <Button text="🚫 Cancel Assignment"
                                onAction="#cancelAssignment"
                                HBox.hgrow="ALWAYS"
                                maxWidth="Infinity"
                                style="-fx-background-color: #FEE2E2;
                                       -fx-text-fill: #DC2626;
                                       -fx-padding: 10;
                                       -fx-background-radius: 8;
                                       -fx-cursor: hand;
                                       -fx-font-size: 11px;"/>
                        <Button text="✖ Clear"
                                onAction="#clearForm"
                                HBox.hgrow="ALWAYS"
                                maxWidth="Infinity"
                                style="-fx-background-color: #F1F5F9;
                                       -fx-text-fill: #475569;
                                       -fx-padding: 10;
                                       -fx-background-radius: 8;
                                       -fx-cursor: hand;
                                       -fx-font-size: 11px;"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </HBox>
</VBox>