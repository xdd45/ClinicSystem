<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.clinic.controller.RegisterController"
           prefWidth="900" prefHeight="620">

    <HBox>

        <!-- LEFT PANEL -->
        <VBox fx:id="leftPanel" prefWidth="380"
              alignment="CENTER" spacing="20"
              style="-fx-background-color: #0F172A;
                     -fx-padding: 50;">

            <StackPane>
                <Circle fx:id="roleCircle" radius="50"
                        style="-fx-fill: #1D4ED8;"/>
                <Label fx:id="roleIcon"
                       style="-fx-font-size: 36px;"/>
            </StackPane>

            <VBox alignment="CENTER" spacing="6">
                <Label fx:id="roleTitle"
                       text="Create Account"
                       style="-fx-font-size: 22px;
                              -fx-font-weight: bold;
                              -fx-text-fill: white;"/>
                <Label fx:id="roleSubLabel"
                       style="-fx-font-size: 13px;
                              -fx-text-fill: #60A5FA;"/>
            </VBox>

            <Separator
                style="-fx-background-color: #1E293B;"/>

            <!-- Info about the role -->
            <VBox fx:id="roleInfoBox" spacing="10"
                  style="-fx-padding: 8 0;"/>

            <!-- Note about admin approval -->
            <VBox spacing="6"
                  style="-fx-background-color: #1E293B;
                         -fx-padding: 14;
                         -fx-background-radius: 8;">
                <Label text="ℹ️  Important"
                       style="-fx-font-size: 12px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #60A5FA;"/>
                <Label text="Your account will be visible to the Admin after registration. Please wait for activation if required."
                       wrapText="true"
                       style="-fx-font-size: 11px;
                              -fx-text-fill: #94A3B8;"/>
            </VBox>

            <!-- Back to login -->
            <Button text="← Back to Login"
                    onAction="#goBackToLogin"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #475569;
                           -fx-font-size: 12px;
                           -fx-cursor: hand;
                           -fx-padding: 8 0;"/>
        </VBox>

        <!-- RIGHT PANEL - Registration Form -->
        <VBox prefWidth="520" alignment="TOP_CENTER"
              spacing="0"
              style="-fx-background-color: #F8FAFC;
                     -fx-padding: 40 50;">

            <Label text="Create Your Account"
                   style="-fx-font-size: 22px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #0F172A;
                          -fx-padding: 0 0 4 0;"/>
            <Label text="Fill in all required fields below"
                   style="-fx-font-size: 12px;
                          -fx-text-fill: #64748B;
                          -fx-padding: 0 0 20 0;"/>

            <ScrollPane fitToWidth="true"
                        style="-fx-background: transparent;
                               -fx-background-color: transparent;"
                        prefHeight="440">
                <VBox spacing="12"
                      style="-fx-padding: 0 4 0 0;">

                    <!-- Full Name -->
                    <VBox spacing="4">
                        <Label text="FULL NAME *"
                               style="-fx-font-size: 11px;
                                      -fx-text-fill: #64748B;
                                      -fx-font-weight: bold;"/>
                        <TextField fx:id="fullNameField"
                                   promptText="e.g. Juan Dela Cruz"
                                   style="-fx-background-color: white;
                                          -fx-border-color: #E2E8F0;
                                          -fx-border-radius: 8;
                                          -fx-background-radius: 8;
                                          -fx-padding: 11;
                                          -fx-font-size: 13px;"/>
                    </VBox>

                    <!-- Username -->
                    <VBox spacing="4">
                        <Label text="USERNAME *"
                               style="-fx-font-size: 11px;
                                      -fx-text-fill: #64748B;
                                      -fx-font-weight: bold;"/>
                        <TextField fx:id="usernameField"
                                   promptText="e.g. juan.delacruz"
                                   style="-fx-background-color: white;
                                          -fx-border-color: #E2E8F0;
                                          -fx-border-radius: 8;
                                          -fx-background-radius: 8;
                                          -fx-padding: 11;
                                          -fx-font-size: 13px;"/>
                        <Label fx:id="usernameStatus"
                               text=""
                               style="-fx-font-size: 11px;"/>
                    </VBox>

                    <!-- Email -->
                    <VBox spacing="4">
                        <Label text="EMAIL ADDRESS"
                               style="-fx-font-size: 11px;
                                      -fx-text-fill: #64748B;
                                      -fx-font-weight: bold;"/>
                        <TextField fx:id="emailField"
                                   promptText="e.g. juan@email.com"
                                   style="-fx-background-color: white;
                                          -fx-border-color: #E2E8F0;
                                          -fx-border-radius: 8;
                                          -fx-background-radius: 8;
                                          -fx-padding: 11;
                                          -fx-font-size: 13px;"/>
                    </VBox>

                    <!-- Phone -->
                    <VBox spacing="4">
                        <Label text="PHONE NUMBER"
                               style="-fx-font-size: 11px;
                                      -fx-text-fill: #64748B;
                                      -fx-font-weight: bold;"/>
                        <TextField fx:id="phoneField"
                                   promptText="e.g. 09171234567"
                                   style="-fx-background-color: white;
                                          -fx-border-color: #E2E8F0;
                                          -fx-border-radius: 8;
                                          -fx-background-radius: 8;
                                          -fx-padding: 11;
                                          -fx-font-size: 13px;"/>
                    </VBox>

                    <!-- Role (read-only — set from login page) -->
                    <VBox spacing="4">
                        <Label text="ROLE"
                               style="-fx-font-size: 11px;
                                      -fx-text-fill: #64748B;
                                      -fx-font-weight: bold;"/>
                        <TextField fx:id="roleField"
                                   editable="false"
                                   style="-fx-background-color: #F1F5F9;
                                          -fx-border-color: #E2E8F0;
                                          -fx-border-radius: 8;
                                          -fx-background-radius: 8;
                                          -fx-padding: 11;
                                          -fx-font-size: 13px;
                                          -fx-text-fill: #475569;"/>
                    </VBox>

                    <!-- Password -->
                    <VBox spacing="4">
                        <Label text="PASSWORD *"
                               style="-fx-font-size: 11px;
                                      -fx-text-fill: #64748B;
                                      -fx-font-weight: bold;"/>
                        <PasswordField fx:id="passwordField"
                                       promptText="Min. 6 characters"
                                       style="-fx-background-color: white;
                                              -fx-border-color: #E2E8F0;
                                              -fx-border-radius: 8;
                                              -fx-background-radius: 8;
                                              -fx-padding: 11;
                                              -fx-font-size: 13px;"/>
                    </VBox>

                    <!-- Confirm Password -->
                    <VBox spacing="4">
                        <Label text="CONFIRM PASSWORD *"
                               style="-fx-font-size: 11px;
                                      -fx-text-fill: #64748B;
                                      -fx-font-weight: bold;"/>
                        <PasswordField fx:id="confirmField"
                                       promptText="Re-enter your password"
                                       style="-fx-background-color: white;
                                              -fx-border-color: #E2E8F0;
                                              -fx-border-radius: 8;
                                              -fx-background-radius: 8;
                                              -fx-padding: 11;
                                              -fx-font-size: 13px;"/>
                    </VBox>

                    <!-- Status Message -->
                    <Label fx:id="statusLabel" text=""
                           wrapText="true"
                           style="-fx-font-size: 12px;"/>

                    <!-- Register Button -->
                    <Button fx:id="registerButton"
                            text="✅  Create Account"
                            maxWidth="Infinity"
                            onAction="#handleRegister"
                            style="-fx-background-color: #1D4ED8;
                                   -fx-text-fill: white;
                                   -fx-font-size: 14px;
                                   -fx-padding: 13;
                                   -fx-background-radius: 8;
                                   -fx-cursor: hand;
                                   -fx-font-weight: bold;"/>

                    <!-- Already have account -->
                    <HBox alignment="CENTER" spacing="4">
                        <Label text="Already have an account?"
                               style="-fx-font-size: 12px;
                                      -fx-text-fill: #64748B;"/>
                        <Button text="Sign In"
                                onAction="#goBackToLogin"
                                style="-fx-background-color: transparent;
                                       -fx-text-fill: #1D4ED8;
                                       -fx-font-size: 12px;
                                       -fx-cursor: hand;
                                       -fx-font-weight: bold;
                                       -fx-padding: 0;"/>
                    </HBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </HBox>
</StackPane>