<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.clinic.controller.LoginController"
           prefWidth="1000" prefHeight="620"
           minWidth="1000" minHeight="620"
           style="-fx-background-color: #F8FAFC;">

    <HBox prefWidth="1000" prefHeight="620">

        <!-- LEFT PANEL -->
        <VBox prefWidth="400" minWidth="400"
              alignment="CENTER" spacing="20"
              style="-fx-background-color: #0F172A;
                     -fx-padding: 50 40;">

            <StackPane>
                <Circle fx:id="roleCircle"
                        radius="50"/>
                <Label fx:id="roleIcon"
                       style="-fx-font-size: 38px;"/>
            </StackPane>

            <VBox alignment="CENTER" spacing="6">
                <Label fx:id="roleTitle"
                       style="-fx-font-size: 24px;
                              -fx-font-weight: bold;
                              -fx-text-fill: white;"/>
                <Label text="BHC Management System"
                       style="-fx-font-size: 12px;
                              -fx-text-fill: #60A5FA;"/>
            </VBox>

            <Separator
                style="-fx-background-color: #1E293B;"/>

            <!-- Access list -->
            <VBox fx:id="accessList"
                  spacing="10"
                  style="-fx-padding: 8 0;"/>

            <!-- Back button -->
            <Button text="← Back to Role Selection"
                    onAction="#goBack"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #475569;
                           -fx-font-size: 12px;
                           -fx-cursor: hand;
                           -fx-padding: 8 0;
                           -fx-border-color: transparent;"/>
        </VBox>

        <!-- RIGHT PANEL -->
        <VBox HBox.hgrow="ALWAYS"
              alignment="CENTER"
              spacing="0"
              style="-fx-background-color: #F8FAFC;
                     -fx-padding: 60 60;">

            <!-- Welcome Text -->
            <VBox spacing="6"
                  style="-fx-padding: 0 0 28 0;">
                <Label text="Welcome back 👋"
                       style="-fx-font-size: 26px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #0F172A;"/>
                <Label fx:id="roleSubtitle"
                       style="-fx-font-size: 13px;
                              -fx-text-fill: #64748B;"/>
            </VBox>

            <!-- Username -->
            <VBox spacing="6"
                  style="-fx-padding: 0 0 14 0;">
                <Label text="USERNAME"
                       style="-fx-font-size: 11px;
                              -fx-text-fill: #64748B;
                              -fx-font-weight: bold;"/>
                <TextField fx:id="usernameField"
                           promptText="Enter your username"
                           maxWidth="Infinity"
                           style="-fx-background-color: white;
                                  -fx-border-color: #E2E8F0;
                                  -fx-border-radius: 8;
                                  -fx-background-radius: 8;
                                  -fx-padding: 12;
                                  -fx-font-size: 13px;"/>
            </VBox>

            <!-- Password -->
            <VBox spacing="6"
                  style="-fx-padding: 0 0 10 0;">
                <Label text="PASSWORD"
                       style="-fx-font-size: 11px;
                              -fx-text-fill: #64748B;
                              -fx-font-weight: bold;"/>
                <PasswordField fx:id="passwordField"
                               promptText="Enter your password"
                               maxWidth="Infinity"
                               style="-fx-background-color: white;
                                      -fx-border-color: #E2E8F0;
                                      -fx-border-radius: 8;
                                      -fx-background-radius: 8;
                                      -fx-padding: 12;
                                      -fx-font-size: 13px;"/>
            </VBox>

            <!-- Error Label -->
            <Label fx:id="errorLabel"
                   text="" wrapText="true"
                   maxWidth="Infinity"
                   style="-fx-text-fill: #EF4444;
                          -fx-font-size: 12px;
                          -fx-padding: 8 12;
                          -fx-background-color: #FEE2E2;
                          -fx-background-radius: 6;
                          -fx-min-height: 0;"/>

            <!-- Sign In Button -->
            <Button fx:id="loginButton"
                    text="Sign In →"
                    maxWidth="Infinity"
                    onAction="#handleLogin"
                    style="-fx-text-fill: white;
                           -fx-font-size: 14px;
                           -fx-padding: 14;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;
                           -fx-font-weight: bold;
                           -fx-margin: 14 0 0 0;"/>

            <!-- Don't have an account -->
            <HBox alignment="CENTER" spacing="4"
                  style="-fx-padding: 14 0 0 0;">
                <Label text="Don't have an account?"
                       style="-fx-font-size: 12px;
                              -fx-text-fill: #64748B;"/>
                <Button text="Create one here"
                        onAction="#goToRegister"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #1D4ED8;
                               -fx-font-size: 12px;
                               -fx-cursor: hand;
                               -fx-font-weight: bold;
                               -fx-padding: 0;
                               -fx-border-color: transparent;"/>
            </HBox>

            <!-- Footer -->
            <VBox alignment="CENTER"
                  style="-fx-padding: 20 0 0 0;">
                <Separator/>
                <Label text="🔒 Secured  |  Cloud-Synced via Supabase"
                       style="-fx-font-size: 10px;
                              -fx-text-fill: #CBD5E1;
                              -fx-padding: 10 0 0 0;"/>
            </VBox>

        </VBox>
    </HBox>
</StackPane>