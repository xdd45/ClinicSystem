<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.clinic.controller.PatientPortalController"
            style="-fx-background-color: #F8FAFC;">
    <left>
        <VBox prefWidth="240"
              style="-fx-background-color: #2E1065;">

            <VBox style="-fx-padding: 24 20;
                         -fx-background-color: #1E1040;">
                <HBox spacing="12"
                      alignment="CENTER_LEFT">
                    <StackPane>
                        <Circle radius="20"
                                style="-fx-fill: #8B5CF6;"/>
                        <Label text="🧑"
                               style="-fx-font-size: 14px;"/>
                    </StackPane>
                    <VBox>
                        <Label text="Patient Portal"
                               style="-fx-font-size: 14px;
                                      -fx-font-weight: bold;
                                      -fx-text-fill: white;"/>
                        <Label text="My Health Records"
                               style="-fx-font-size: 11px;
                                      -fx-text-fill: #C4B5FD;"/>
                    </VBox>
                </HBox>
            </VBox>

            <HBox spacing="10" alignment="CENTER_LEFT"
                  style="-fx-padding: 12 16;
                         -fx-background-color: #3B0764;">
                <Label text="👤"
                       style="-fx-font-size: 16px;"/>
                <Label fx:id="userLabel"
                       style="-fx-font-size: 12px;
                              -fx-text-fill: #EDE9FE;
                              -fx-font-weight: bold;"/>
            </HBox>

            <Separator
                style="-fx-background-color: #3B0764;"/>

            <Label text="MY PORTAL"
                   style="-fx-font-size: 10px;
                          -fx-text-fill: #C4B5FD;
                          -fx-padding: 16 20 8 20;
                          -fx-font-weight: bold;"/>

            <Button text="🏠   My Dashboard"
                    maxWidth="Infinity"
                    onAction="#showDashboard"
                    style="-fx-background-color: #8B5CF6;
                           -fx-text-fill: white;
                           -fx-alignment: CENTER_LEFT;
                           -fx-padding: 12 20;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;"/>
            <Button text="📅   My Appointments"
                    maxWidth="Infinity"
                    onAction="#showMyAppointments"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #EDE9FE;
                           -fx-alignment: CENTER_LEFT;
                           -fx-padding: 12 20;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;"/>
            <Button text="🩺   My Medical Records"
                    maxWidth="Infinity"
                    onAction="#showMyRecords"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #EDE9FE;
                           -fx-alignment: CENTER_LEFT;
                           -fx-padding: 12 20;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;"/>
            <Button text="💰   My Bills"
                    maxWidth="Infinity"
                    onAction="#showMyBills"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #EDE9FE;
                           -fx-alignment: CENTER_LEFT;
                           -fx-padding: 12 20;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;"/>

            <Region VBox.vgrow="ALWAYS"/>
            <Separator
                style="-fx-background-color: #3B0764;"/>
            <Button text="🚪   Sign Out"
                    maxWidth="Infinity"
                    onAction="#handleLogout"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #FCA5A5;
                           -fx-alignment: CENTER_LEFT;
                           -fx-padding: 14 20;
                           -fx-font-size: 13px;
                           -fx-cursor: hand;"/>
        </VBox>
    </left>
    <center>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="16"
                  style="-fx-background-color: white;
                         -fx-padding: 16 24;
                         -fx-effect: dropshadow(gaussian,
                           rgba(0,0,0,0.06),8,0,0,2);">
                <Label fx:id="pageTitle"
                       text="My Dashboard"
                       style="-fx-font-size: 18px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #0F172A;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="dateLabel"
                       style="-fx-font-size: 12px;
                              -fx-text-fill: #64748B;"/>
            </HBox>
            <StackPane fx:id="contentArea"
                       style="-fx-padding: 24;"
                       VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>
</BorderPane>