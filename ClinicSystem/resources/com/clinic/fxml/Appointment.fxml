<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.clinic.controller.AppointmentController"
      spacing="0" style="-fx-background-color: #F8FAFC;">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-padding: 0 0 20 0;">
        <VBox>
            <Label text="Appointment Scheduling"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;
                          -fx-text-fill: #0F172A;"/>
            <Label text="Schedule and manage patient appointments"
                   style="-fx-font-size: 12px; -fx-text-fill: #64748B;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="➕  New Appointment" onAction="#clearForm"
                style="-fx-background-color: #10B981; -fx-text-fill: white;
                       -fx-padding: 10 20; -fx-background-radius: 8;
                       -fx-cursor: hand; -fx-font-weight: bold;"/>
    </HBox>

    <!-- FILTER BAR -->
    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-padding: 0 0 16 0;">
        <TextField fx:id="searchField"
                   promptText="🔍  Search by patient name..."
                   prefWidth="280"
                   style="-fx-padding: 10 16; -fx-background-radius: 8;
                          -fx-border-color: #E2E8F0; -fx-border-radius: 8;
                          -fx-background-color: white;"/>
        <DatePicker fx:id="filterDate" promptText="Filter by Date"/>
        <ComboBox fx:id="filterStatus" promptText="All Status"
                  style="-fx-background-radius: 8;"/>
        <Button text="🔄 Reset" onAction="#resetFilter"
                style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569;
                       -fx-padding: 10 16; -fx-background-radius: 8;
                       -fx-cursor: hand;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="countLabel"
               style="-fx-font-size: 12px; -fx-text-fill: #64748B;"/>
    </HBox>

    <!-- CONTENT -->
    <HBox spacing="16" VBox.vgrow="ALWAYS">

        <!-- TABLE -->
        <TableView fx:id="apptTable" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: white; -fx-background-radius: 12;
                          -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),12,0,0,4);">
            <columns>
                <TableColumn fx:id="colId"      text="ID"       prefWidth="55"/>
                <TableColumn fx:id="colPatient" text="Patient"  prefWidth="180"/>
                <TableColumn fx:id="colDate"    text="Date"     prefWidth="120"/>
                <TableColumn fx:id="colTime"    text="Time"     prefWidth="100"/>
                <TableColumn fx:id="colReason"  text="Reason"   prefWidth="180"/>
                <TableColumn fx:id="colStatus"  text="Status"   prefWidth="120"/>
            </columns>
            <placeholder>
                <Label text="No appointments found."
                       style="-fx-text-fill: #94A3B8;"/>
            </placeholder>
        </TableView>

        <!-- FORM -->
        <VBox prefWidth="300" spacing="0"
              style="-fx-background-color: white; -fx-background-radius: 12;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),12,0,0,4);">

            <VBox style="-fx-padding: 16 20; -fx-background-color: #10B981;
                         -fx-background-radius: 12 12 0 0;">
                <Label fx:id="formTitle" text="New Appointment"
                       style="-fx-font-size: 15px; -fx-font-weight: bold;
                              -fx-text-fill: white;"/>
                <Label text="Fill in appointment details"
                       style="-fx-font-size: 11px; -fx-text-fill: #D1FAE5;"/>
            </VBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background: transparent;
                               -fx-background-color: transparent;">
                <VBox spacing="12" style="-fx-padding: 16;">

                    <Label text="PATIENT *"
                           style="-fx-font-size: 11px; -fx-text-fill: #64748B;
                                  -fx-font-weight: bold;"/>
                    <ComboBox fx:id="patientCombo" maxWidth="Infinity"
                              promptText="Select patient..."
                              style="-fx-font-size: 13px;"/>

                    <Label text="DATE *"
                           style="-fx-font-size: 11px; -fx-text-fill: #64748B;
                                  -fx-font-weight: bold;"/>
                    <DatePicker fx:id="datePicker" maxWidth="Infinity"/>

                    <Label text="TIME *"
                           style="-fx-font-size: 11px; -fx-text-fill: #64748B;
                                  -fx-font-weight: bold;"/>
                    <ComboBox fx:id="timeCombo" maxWidth="Infinity"
                              style="-fx-font-size: 13px;"/>

                    <Label text="REASON FOR VISIT"
                           style="-fx-font-size: 11px; -fx-text-fill: #64748B;
                                  -fx-font-weight: bold;"/>
                    <TextField fx:id="reasonField"
                               promptText="e.g. General Checkup"
                               style="-fx-padding: 10; -fx-border-color: #E2E8F0;
                                      -fx-border-radius: 8; -fx-background-radius: 8;"/>

                    <Label text="STATUS"
                           style="-fx-font-size: 11px; -fx-text-fill: #64748B;
                                  -fx-font-weight: bold;"/>
                    <ComboBox fx:id="statusCombo" maxWidth="Infinity"
                              style="-fx-font-size: 13px;"/>

                    <Label text="NOTES"
                           style="-fx-font-size: 11px; -fx-text-fill: #64748B;
                                  -fx-font-weight: bold;"/>
                    <TextArea fx:id="notesArea" prefRowCount="3"
                              promptText="Additional notes..."
                              style="-fx-border-color: #E2E8F0;
                                     -fx-border-radius: 8;"/>

                    <Label fx:id="statusLabel" text="" wrapText="true"
                           style="-fx-font-size: 12px;"/>

                    <Button fx:id="saveButton" text="💾  Save Appointment"
                            maxWidth="Infinity" onAction="#handleSave"
                            style="-fx-background-color: #10B981;
                                   -fx-text-fill: white; -fx-font-size: 13px;
                                   -fx-padding: 12; -fx-background-radius: 8;
                                   -fx-cursor: hand; -fx-font-weight: bold;"/>

                    <HBox spacing="8">
                        <Button text="✅ Complete" onAction="#markComplete"
                                HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                style="-fx-background-color: #DBEAFE;
                                       -fx-text-fill: #1D4ED8;
                                       -fx-padding: 10; -fx-background-radius: 8;
                                       -fx-cursor: hand; -fx-font-size: 12px;"/>
                        <Button text="❌ Cancel" onAction="#markCancelled"
                                HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                style="-fx-background-color: #FEE2E2;
                                       -fx-text-fill: #DC2626;
                                       -fx-padding: 10; -fx-background-radius: 8;
                                       -fx-cursor: hand; -fx-font-size: 12px;"/>
                    </HBox>

                    <Button text="✖  Clear Form" onAction="#clearForm"
                            maxWidth="Infinity"
                            style="-fx-background-color: #F1F5F9;
                                   -fx-text-fill: #475569; -fx-padding: 10;
                                   -fx-background-radius: 8; -fx-cursor: hand;"/>
                </VBox>
            </ScrollPane>
        </VBox>
    </HBox>
</VBox>